## Revenons à notre `UserEmail`

```rust
use validator::ValidateEmail;

#[derive(Debug)]
pub struct UserEmail(String);

impl UserEmail {               +-------------------------+
    pub fn parse(s: String) -> |Result<UserEmail, String>| {
                               +-------------------------+
        if s.validate_email() {
           +-----------+
           |Ok(Self(s))|
           +-----------+
        } else {
           +-----------------------------------------------+
           |Err(format!("{} is not a valid user email", s))|
           +-----------------------------------------------+
        }
    }
}
```

